								<ui:Column width="60px" sortProperty="misses" filterProperty="misses">
									<ui:multiLabels>
										<Text text="{i18n>groupReadThroughOps}" />
										<Text text="{i18n>colMisses}" />
									</ui:multiLabels>
									<ui:template>
										<Text text="{path: 'misses', type: 'sap.ui.model.type.Integer'}" />
