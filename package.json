{
  "name": "cds-caching",
  "version": "1.3.2",
  "description": "A caching plugin for SAP CAP applications",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikezaschka/cds-caching.git"
  },
  "keywords": [
    "sap",
    "cap",
    "cds",
    "caching",
    "redis",
    "hana",
    "keyv"
  ],
  "author": "Mike Zaschka <opensource@mikezaschka.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mikezaschka/cds-caching/issues"
  },
  "homepage": "https://github.com/mikezaschka/cds-caching#readme",
  "main": "cds-plugin.js",
  "types": "lib/CachingService.d.ts",
  "files": [
    "db/**",
    "srv/**",
    "index.cds",
    "lib/**",
    "app/dashboard/**",
    "app/dashboard-src/**"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cds8": "bash scripts/docker-test-cds.sh 8",
    "test:cds9": "bash scripts/docker-test-cds.sh 9",
    "test:cds10": "bash scripts/docker-test-cds.sh 10",
    "test:matrix": "bash scripts/docker-test-matrix.sh",
    "test:docker:start": "docker compose -f test/docker/docker-compose.yaml up -d --wait",
    "test:docker:stop": "docker compose -f test/docker/docker-compose.yaml down",
    "test:all": "npm run test:docker:start && npm test; status=$?; npm run test:docker:stop; exit $status",
    "lint": "eslint .",
    "release": "release-it",
    "sync:dashboard-webapp": "rm -rf app/webapp && cp -R app/dashboard-src app/webapp",
    "build:dashboard": "npm run sync:dashboard-webapp && cd app && ui5 build self-contained --clean-dest --all --config dashboard.build.ui5.yaml --dest dashboard",
    "start:dashboard": "npm run sync:dashboard-webapp && cd app && ui5 serve --config dashboard.ui5.yaml -o index.html",
    "lint:dashboard": "npm run sync:dashboard-webapp && eslint -c app/dashboard.eslint.config.mjs app/webapp",
    "typecheck:dashboard": "npm run sync:dashboard-webapp && tsc -p app/tsconfig.json --noEmit",
    "prepublishOnly": "npm run build:dashboard"
  },
  "peerDependencies": {
    "@keyv/compress-gzip": "^2.0.3",
    "@keyv/compress-lz4": "^1.0.1",
    "@keyv/postgres": "^4.0.5",
    "@keyv/redis": "^5.0.0",
    "@keyv/sqlite": "^4.0.5",
    "@opentelemetry/api": "^1.0.0",
    "@resolid/keyv-sqlite": "^4.0.5",
    "@sap/cds": ">=8",
    "@sap/cds-dk": ">=8",
    "keyv-hana": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    },
    "@keyv/redis": {
      "optional": true
    },
    "@keyv/sqlite": {
      "optional": true
    },
    "@keyv/compress-lz4": {
      "optional": true
    },
    "@keyv/compress-gzip": {
      "optional": true
    },
    "@resolid/keyv-sqlite": {
      "optional": true
    },
    "@keyv/postgres": {
      "optional": true
    },
    "keyv-hana": {
      "optional": true
    }
  },
  "workspaces": [
    ".",
    "app",
    "test/app",
    "examples/app"
  ],
  "dependencies": {
    "keyv": "^5.6.0"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^0.4.1",
    "@keyv/compress-gzip": "~2.0.3",
    "@keyv/compress-lz4": "~1.0.1",
    "@keyv/postgres": "~2.2.3",
    "@keyv/sqlite": "~4.0.8",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-metrics": "^1.30.1",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@opentelemetry/sdk-trace-node": "^1.30.1",
    "@openui5/types": "^1.136.1",
    "@release-it/conventional-changelog": "^10.0.5",
    "@resolid/keyv-sqlite": "~5.0.1",
    "@sap/cds": "^10",
    "@sap/cds-dk": "^10",
    "@ui5/cli": "^4.0.8",
    "eslint": "^10.0.0",
    "express": "^4.22.2",
    "globals": "^15.11.0",
    "husky": "^9.1.7",
    "release-it": "^19.2.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.8.1",
    "ui5-middleware-cap": "^3.3.0",
    "ui5-middleware-livereload": "^3.1.0",
    "ui5-tooling-transpile": "^3.5.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22"
  },
  "cds": {
    "requires": {
      "kinds": {
        "cds-caching": {
          "impl": "cds-caching"
        },
        "caching": {
          "impl": "cds-caching"
        }
      }
    }
  }
}
