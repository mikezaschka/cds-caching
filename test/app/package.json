{
  "name": "cds-caching-test",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "repository": "<Add your repository here>",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@sap-cloud-sdk/http-client": "~4.0.2",
    "@sap-cloud-sdk/resilience": "~4.0.2",
    "@sap/cds": "^10",
    "cds-caching": "*",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/cds-types": "^0.18.0",
    "@cap-js/sqlite": "^3.0.2",
    "@keyv/postgres": "~2.2.3",
    "@resolid/keyv-sqlite": "^5.0.1",
    "pgpass": "~1.0.5"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite"
      },
      "caching": {
        "impl": "cds-caching",
        "namespace": "testCache",
        "store": "memory",
        "metrics": {
          "enabled": true,
          "persistenceInterval": 10000,
          "maxLatencies": 1000
        }
      },
      "caching-northwind": {
        "impl": "cds-caching",
        "namespace": "northwind",
        "store": "sqlite",
        "credentials": {
          "url": "file::memory:"
        }
      },
      "Northwind": {
        "kind": "odata",
        "model": "srv/external/Northwind",
        "credentials": {
          "url": "https://services.odata.org/Experimental/OData/OData.svc/"
        }
      },
      "caching-postgres": {
        "impl": "cds-caching",
        "namespace": "postgres",
        "store": "postgres",
        "credentials": {
          "url": "postgresql://postgres:postgres@localhost:5432/postgres",
          "schema": "public",
          "table": "cache"
        },
        "[docker]": {
          "credentials": {
            "url": "postgresql://postgres:postgres@postgres:5432/postgres"
          }
        }
      },
      "caching-redis": {
        "impl": "cds-caching",
        "namespace": "redis",
        "store": "redis",
        "credentials": {
          "socket": {
            "host": "localhost",
            "port": 6379,
            "keepAlive": true,
            "pingInterval": 1000
          }
        },
        "[docker]": {
          "credentials": {
            "socket": {
              "host": "redis"
            }
          }
        }
      },
      "caching-sqlite": {
        "impl": "cds-caching",
        "namespace": "sqlite",
        "store": "sqlite",
        "credentials": {
          "url": "file::memory:"
        }
      },
      "caching-in-memory": {
        "impl": "cds-caching",
        "namespace": "in-memory",
        "store": "memory"
      },
      "caching-cds": {
        "impl": "cds-caching",
        "namespace": "cds-store",
        "store": "cds"
      }
    }
  }
}
