ARG CDS_MAJOR=10
FROM node:22-bookworm

# @cap-js/sqlite@1 (cds 8) and @2 (cds 9) may compile native addons.
RUN apt-get update \
    && apt-get install -y --no-install-recommends python3 make g++ \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

ARG CDS_MAJOR=10
ENV CDS_MAJOR=${CDS_MAJOR}

COPY package.json package-lock.json ./
COPY test/app/package.json test/app/
COPY examples/app/package.json examples/app/
COPY test/docker/install-cds.sh test/docker/configure-test-app-db.sh test/docker/

RUN chmod +x test/docker/install-cds.sh test/docker/configure-test-app-db.sh \
    && CDS_MAJOR=${CDS_MAJOR} test/docker/install-cds.sh

COPY . .

RUN chmod +x test/docker/configure-test-app-db.sh \
    && CDS_MAJOR=${CDS_MAJOR} test/docker/configure-test-app-db.sh

CMD ["npm", "test"]
